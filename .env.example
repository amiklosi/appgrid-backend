# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration
# For local development with SQLite
DATABASE_URL="file:./dev.db"

# For Docker/Production with PostgreSQL (uncomment when needed)
# DATABASE_URL=postgresql://appgrid_user:appgrid_password@localhost:5432/appgrid_db

# OpenAI (required for AI rearrange feature)
OPENAI_API_KEY=sk-...

# Paddle (payments)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# RevenueCat (legacy migration)
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=

# Mailgun (transactional email)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Optional
ALERT_EMAIL=
TRIAL_DURATION_DAYS=7
POSTHOG_API_KEY=
AXIOM_TOKEN=
AXIOM_DATASET=

